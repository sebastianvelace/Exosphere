<Project Sdk="Godot.NET.Sdk/4.6.3">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Exosphere.Game</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="ExosphereSimulation/ExosphereSimulation.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="ExosphereSimulation/**/*.cs" />
    <Compile Remove="ExosphereSimulation.Tests/**/*.cs" />
    <Compile Remove=".godot/**/*.cs" />
  </ItemGroup>
</Project>
